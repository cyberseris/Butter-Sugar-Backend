# PostgreSQL 容器設定
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# 雲端主機設定
# DB_HOST=postgres  
# 本地連接請改成 DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SYNCHRONIZE=true
DB_ENABLE_SSL=false
PORT=8080
LOG_LEVEL=debug
JWT_EXPIRES_DAY=30d
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=